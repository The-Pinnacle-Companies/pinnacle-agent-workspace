# =============================================================================
# AI Agent Workspace — Environment Variables
# Copy this file to .env.local for local development
# =============================================================================

# -----------------------------------------------------------------------------
# DATABASE
# -----------------------------------------------------------------------------
# PostgreSQL connection string
# Local dev: use the Docker compose DB below
# Production: Azure Database for PostgreSQL
DATABASE_URL="postgresql://agws_user:agws_password@localhost:5432/agent_workspace?schema=public"

# -----------------------------------------------------------------------------
# AUTH (Auth.js v5 / NextAuth)
# -----------------------------------------------------------------------------
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET="your-nextauth-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# MICROSOFT ENTRA ID (Azure AD)
# Register an app at https://portal.azure.com → App registrations
# Required API permissions: User.Read, GroupMember.Read.All
# -----------------------------------------------------------------------------
AZURE_AD_CLIENT_ID="your-azure-ad-client-id"
AZURE_AD_CLIENT_SECRET="your-azure-ad-client-secret"
AZURE_AD_TENANT_ID="your-azure-ad-tenant-id"

# -----------------------------------------------------------------------------
# OPENCLAW ADAPTERS
# -----------------------------------------------------------------------------
# Friday agent gateway (OpenClaw instance)
OPENCLAW_FRIDAY_GATEWAY_URL="https://friday.collectivedg.com"
OPENCLAW_FRIDAY_AUTH_TOKEN="your-friday-auth-token"

# Flynn agent gateway (optional)
OPENCLAW_FLYNN_GATEWAY_URL="https://flynn.collectivedg.com"
OPENCLAW_FLYNN_AUTH_TOKEN="your-flynn-auth-token"

# Set to "mock" to use the mock adapter for local dev (no real OpenClaw needed)
# Set to "openclaw" in production
ADAPTER_MODE="mock"

# -----------------------------------------------------------------------------
# PUSHER (Real-time)
# Sign up at https://pusher.com — create a Channels app
# -----------------------------------------------------------------------------
PUSHER_APP_ID="your-pusher-app-id"
PUSHER_KEY="your-pusher-key"
PUSHER_SECRET="your-pusher-secret"
PUSHER_CLUSTER="us2"

# Client-side (exposed to browser)
NEXT_PUBLIC_PUSHER_KEY="your-pusher-key"
NEXT_PUBLIC_PUSHER_CLUSTER="us2"

# -----------------------------------------------------------------------------
# AZURE BLOB STORAGE (File attachments)
# -----------------------------------------------------------------------------
AZURE_STORAGE_ACCOUNT_NAME="your-storage-account"
AZURE_STORAGE_ACCOUNT_KEY="your-storage-account-key"
AZURE_STORAGE_CONTAINER_NAME="agent-workspace-uploads"

# -----------------------------------------------------------------------------
# APP
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Platform admin Entra group ID (members get PLATFORM_ADMIN role)
PLATFORM_ADMIN_GROUP_ID="your-entra-group-id"
